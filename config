### DO NOT REMOVE MOD LINES
set $mod Mod4
floating_modifier $mod

### DO NOT MOVE FONT LINES
font pango:Iosevka Nerd Font 8

### DO NOT MOVE WORKSPACE LINES
set $primary_display HDMI-0
set $secondary_display eDP-1-1

workspace 1 output $primary_display $secondary_display
workspace 2 output $primary_display $secondary_display
workspace 3 output $primary_display $secondary_display
workspace 4 output $primary_display $secondary_display
workspace 5 output $primary_display $secondary_display
workspace 6 output $secondary_display
workspace 7 output $secondary_display
workspace 8 output $secondary_display
workspace 9 output $secondary_display
workspace 10 output $secondary_display

# Define names for default workspaces for which we configure key bindings later on.
# We use variables to avoid repeating the names in multiple places.
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

workspace_auto_back_and_forth yes

# Monitor layout
include ~/.config/i3/monitors.conf

# Autostart
include ~/.config/i3/autostart.conf

# Window rules
include ~/.config/i3/rules.conf

# Modes
include ~/.config/i3/modes.conf

# Keybindings
include ~/.config/i3/keys.conf

# Colors
include ~/.config/i3/colors.conf

# Gaps
include ~/.config/i3/gaps.conf
